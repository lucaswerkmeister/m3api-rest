{
	"plugins": [
		"chai-friendly"
	],
	"extends": [
		"wikimedia/common",
		"wikimedia/language/es2019",
		"wikimedia/node",
		"plugin:chai-friendly/recommended",
		"plugin:compat/recommended"
	],
	"parserOptions": {
		"sourceType": "module"
	},
	"rules": {
		"comma-dangle": [ "error", "always-multiline" ],
		"no-shadow": "off",
		"prefer-const": [ "error", { "destructuring": "all" } ],
		"jsdoc/no-undefined-types": [ "error", {
			"definedTypes": [ "Options", "Session" ]
		} ]
	},
	"overrides": [
		{
			"files": "*.json",
			"rules": {
				"comma-dangle": "off"
			}
		}
	],
	"ignorePatterns": [
		"/doc/"
	]
}
